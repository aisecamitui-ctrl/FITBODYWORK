<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FitBody Work</title>
<link rel="stylesheet" href="style.css">
<link rel="manifest" href="manifest.json">
</head>

<body>

<div class="header">
    <div class="title-box">
        <h1 class="main-title">FITBODY WORK</h1>
    </div>
</div>

<!-- Goblet Squat -->
<div class="exercise-card">
  <div class="exercise-img">
    <img src="images/goblet-squat.png" alt="Goblet Squat">
  </div>
  <div class="exercise-info">
    <h2>GOBLET SQUAT</h2>
    <button class="btn" onclick="showGoblet()">CLICK</button>
    <p id="gobletMessage" class="message"></p>
  </div>
</div>

<!-- Sit-Up -->
<div class="exercise-card">
  <div class="exercise-img">
    <img src="images/situp.png" alt="Sit-Up">
  </div>
  <div class="exercise-info">
    <h2>SIT-UP</h2>
    <button class="btn" onclick="showSitup()">CLICK</button>
    <p id="situpMessage" class="message"></p>
  </div>
</div>

<!-- Pushup -->
<div class="exercise-card">
  <div class="exercise-img">
    <img src="images/pushup.png" alt="Pushup">
  </div>
  <div class="exercise-info">
    <h2>PUSHUP</h2>
    <button class="btn" onclick="showPushup()">CLICK</button>
    <p id="pushupMessage" class="message"></p>
  </div>
</div>

<script>
function toggleMessage(id, content) {
    const element = document.getElementById(id);
    element.innerHTML = element.innerHTML === "" ? content : "";
}

function showGoblet() {
    const content =
        "<strong>The goblet squat can improve your squat mechanics, build lower-body endurance, and add muscle to your frame.</strong><br><br>" +
        "<strong>SETS & REPS:</strong> 3 SETS, 12-15 REPS<br><br>" +
        "<strong>BENEFITS:</strong><br>" +
        "Improves Squat Mechanics<br>" +
        "Builds Leg Strength<br>" +
        "Enhances Core Stability<br>" +
        "Increases Mobility";
    toggleMessage("gobletMessage", content);
}

function showSitup() {
    const content =
        "<strong>Situps are classic abdominal exercises done by lying on your back and lifting your torso.</strong><br><br>" +
        "<strong>SETS & REPS:</strong> 2-3 SETS, 5-8 REPS<br><br>" +
        "<strong>BENEFITS:</strong><br>" +
        "Pectoralis major<br>" +
        "Abdominus rectus<br>" +
        "Serratus<br>" +
        "Latissimus dorsi<br>" +
        "External oblique";
    toggleMessage("situpMessage", content);
}

function showPushup() {
    const content =
        "<strong>Push-ups are a fast and effective exercise for building strength.</strong><br><br>" +
        "<strong>SETS & REPS:</strong> 2-3 SETS, 3-5 REPS<br><br>" +
        "<strong>BENEFITS:</strong><br>" +
        "Upper pectoralis major<br>" +
        "Anterior deltoid<br>" +
        "Lower pectoralis major<br>" +
        "Biceps brachii, short head<br>" +
        "Triceps brachii";
    toggleMessage("pushupMessage", content);
}

// Register service worker
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('/service.js')
      .then(reg => console.log('Service Worker registered!', reg))
      .catch(err => console.log('Service Worker registration failed:', err));
  });
}
</script>

</body>
</html>